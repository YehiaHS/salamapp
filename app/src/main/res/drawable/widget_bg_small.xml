<?xml version="1.0" encoding="utf-8"?>
<!-- Small widget background — deep indigo with subtle accent border -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#1A0E35"
        android:centerColor="#120B28"
        android:endColor="#0D0820"
        android:angle="135"/>
    <corners android:radius="20dp"/>
    <stroke
        android:width="1dp"
        android:color="#3D8B9FFF"/>
</shape>
