<?xml version="1.0" encoding="utf-8"?>
<!-- Medium/Large widget background — richer gradient matching app aesthetic -->
<shape xmlns:android="http://schemas.android.com/apk/res/android"
    android:shape="rectangle">
    <gradient
        android:startColor="#1E1040"
        android:centerColor="#140C30"
        android:endColor="#0A0820"
        android:angle="150"/>
    <corners android:radius="24dp"/>
    <stroke
        android:width="1dp"
        android:color="#2D8B9FFF"/>
</shape>
