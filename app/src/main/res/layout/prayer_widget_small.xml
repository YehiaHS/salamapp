<?xml version="1.0" encoding="utf-8"?>
<!--
    SMALL WIDGET (2×2) — prayer_widget_small.xml
    Shows: SALAM branding, next prayer name, time, and countdown
    Design: Deep indigo background, periwinkle accent, minimal & elegant
-->
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:id="@+id/widget_small_root"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_bg_small"
    android:padding="14dp">

    <!-- Top row: SALAM branding left, moon icon right -->
    <LinearLayout
        android:id="@+id/widget_small_top"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_alignParentTop="true"
        android:orientation="horizontal"
        android:gravity="center_vertical">

        <TextView
            android:id="@+id/widget_small_brand"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="SALAM"
            android:textColor="#FF8B9FFF"
            android:textSize="10sp"
            android:textStyle="bold"
            android:letterSpacing="0.15"/>

        <TextView
            android:id="@+id/widget_small_hijri"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="15 Ramadan"
            android:textColor="#66FFFFFF"
            android:textSize="9sp"/>
    </LinearLayout>

    <!-- Center-bottom: Prayer name large -->
    <LinearLayout
        android:id="@+id/widget_small_prayer_block"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_below="@id/widget_small_top"
        android:layout_alignParentBottom="true"
        android:orientation="vertical"
        android:gravity="start"
        android:layout_marginTop="6dp">

        <TextView
            android:id="@+id/widget_small_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Prayer"
            android:textColor="#88FFFFFF"
            android:textSize="10sp"/>

        <TextView
            android:id="@+id/widget_small_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Maghrib"
            android:textColor="#FFFFFFFF"
            android:textSize="20sp"
            android:textStyle="bold"/>

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginTop="2dp">

            <TextView
                android:id="@+id/widget_small_time"
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="06:28"
                android:textColor="#FF8B9FFF"
                android:textSize="14sp"
                android:textStyle="bold"/>

            <TextView
                android:id="@+id/widget_small_remaining"
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="2h 15m"
                android:textColor="#FFCD8A"
                android:textSize="10sp"
                android:textStyle="bold"/>
        </LinearLayout>
    </LinearLayout>

</RelativeLayout>
