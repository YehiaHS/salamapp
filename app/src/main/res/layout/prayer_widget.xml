<?xml version="1.0" encoding="utf-8"?>
<RelativeLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@drawable/widget_background"
    android:padding="16dp">

    <!-- App Name / Branding -->
    <TextView
        android:id="@+id/widget_app_title"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="SALAM"
        android:textColor="#00E5A3"
        android:textSize="12sp"
        android:textStyle="bold"
        android:letterSpacing="0.1"
        android:layout_alignParentTop="true"
        android:layout_alignParentLeft="true"/>

    <!-- Hijri Date -->
    <TextView
        android:id="@+id/widget_hijri_date"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="15 Ramadan"
        android:textColor="#88FFFFFF"
        android:textSize="11sp"
        android:layout_alignParentTop="true"
        android:layout_alignParentRight="true"/>

    <!-- Next Prayer Section -->
    <LinearLayout
        android:id="@+id/widget_next_prayer_layout"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:layout_alignParentLeft="true"
        android:layout_below="@id/widget_app_title"
        android:layout_marginTop="8dp"
        android:gravity="left">

        <TextView
            android:id="@+id/widget_next_prayer_label"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Next Prayer"
            android:textColor="#B0FFFFFF"
            android:textSize="12sp"/>

        <TextView
            android:id="@+id/widget_next_prayer_name"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Fajr"
            android:textColor="#FFFFFF"
            android:textSize="22sp"
            android:textStyle="bold"/>
    </LinearLayout>

    <!-- Next Prayer Time Badge/Container -->
    <LinearLayout
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:layout_alignParentBottom="true"
        android:layout_alignParentRight="true"
        android:layout_below="@id/widget_hijri_date"
        android:layout_marginTop="8dp"
        android:gravity="right">

        <TextView
            android:id="@+id/widget_next_prayer_time"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="04:30 AM"
            android:textColor="#00E5A3"
            android:textSize="22sp"
            android:textStyle="bold"/>

        <TextView
            android:id="@+id/widget_time_remaining"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="in 2h 15m"
            android:textColor="#F59E0B"
            android:textSize="11sp"
            android:textStyle="bold"/>
    </LinearLayout>

</RelativeLayout>
